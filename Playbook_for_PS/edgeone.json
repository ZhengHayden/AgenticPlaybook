{
  "version": "1.0",
  "name": "playbook-for-ps",
  "build": {
    "outputDirectory": "."
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/js/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=3600"
      }
    },
    {
      "source": "/(.*\\.html)",
      "headers": {
        "Cache-Control": "no-cache"
      }
    }
  ]
}
