# ─── Agentic Workflow Playbook — environment ───────────────────
# Copy to `.env.local` (git-ignored) and fill in real values.

# Path to the better-sqlite3 database file. Defaults to ./data/playbook.db.
# PLAYBOOK_DB_PATH=./data/playbook.db

# Anthropic API key for the Workflow Understanding Agent. Required only to run
# the agent (SOP analysis). If unset, the agent returns a friendly error and
# the rest of the app works normally. Never commit a real key.
# ANTHROPIC_API_KEY=sk-ant-...

# Model used by the Understanding Agent. Defaults to claude-sonnet-4-6.
# PLAYBOOK_AGENT_MODEL=claude-sonnet-4-6
